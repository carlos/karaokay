---
layout: layouts/base.njk
---
<div class="song-page">
  <div class="song-header">
    <h1 class="song-title">{{ title }}</h1>
    <p class="song-artist">
      {%- for a in artist | toArtistList -%}
        {%- if not loop.first and loop.last %} &amp; {% elif not loop.first %}, {% endif -%}
        <a href="/artists/{{ a | slugify }}/">{{ a }}</a>
      {%- endfor -%}
    </p>
    {% if album %}<p class="song-album"><a href="/albums/{{ album | slugify }}/">{{ album }}</a></p>{% endif %}
    <button class="print-btn" onclick="window.print()" aria-label="Print" title="Print"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg></button>
  </div>
  <div class="lyrics">
    {{ content | safe }}
  </div>
</div>
